# ─── AI chatbot (optional) ───────────────────────────────────────────
# The "Ask my AI" widget works WITHOUT a key (keyless RAG fallback).
# Add a free Google AI Studio key to upgrade to live Gemini answers:
#   https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ─── Contact form (Nodemailer + Gmail SMTP) ──────────────────────────
# 1) Enable 2-Step Verification on your Google account
# 2) Create an App Password: https://myaccount.google.com/apppasswords
# 3) Paste the 16-char password below (no spaces)
GMAIL_USER=arhum.javaid@gmail.com
GMAIL_APP_PASSWORD=
# Where contact submissions are delivered (defaults to GMAIL_USER)
CONTACT_TO=arhum.javaid@gmail.com
